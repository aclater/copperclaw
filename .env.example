# LLM Backend — default is local RamaLama
# Set LLM_BACKEND=anthropic to use Anthropic API instead
LLM_BACKEND=ramalama
LLM_MODEL=qwen2.5:14b
RAMALAMA_BASE_URL=http://localhost:8080/v1

# Only required if LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Database
DB_HOST=localhost
DB_USER=copperclaw
DB_PASSWORD=copperclaw
DB_NAME=copperclaw

# Service URLs
STATE_SERVICE_URL=http://localhost:8089
SSE_BRIDGE_URL=http://localhost:8090

# CoT Gateway simulation mode
COT_SIMULATION_MODE=true
COT_SIMULATION_INTERVAL_SECONDS=30
